            class rhsusf_m113_usarmy_M2_90 {
                displayName = "M113A3";
                description = "Бронетранспортёр США 1960-х годов. Разработан в 1957—1959 годах. Запущен в серийное производство в январе 1960 года, производство продолжалось до 2007 года. Длительное время оставался основным бронетранспортёром США, в значительных количествах поставлялся также в другие страны и использовался во множестве вооружённых конфликтов. Поставляется с пулемётом M2.";
                amount = 1;
                price = 800;
                stock = 1000;
                spawnEmpty = 1;
